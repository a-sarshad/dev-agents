{
  "name": "@dev-agents/projfix",
  "version": "0.1.0",
  "description": "Consistency checker & auto-fixer for RTL/LTR projects — DS-agnostic",
  "type": "module",
  "bin": {
    "projfix": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint src --ext .ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": ["rtl", "ltr", "persian", "farsi", "lint", "fix", "chakra", "consistency"],
  "author": "Ali <asarshad@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "chalk": "^5.3.0",
    "glob": "^11.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
